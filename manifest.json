<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>World Cup Penalty Shootout</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #0b1a0e;
            color: #fff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
            touch-action: none;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }
        
        #gameContainer {
            position: relative;
            width: 100%;
            max-width: 400px;
            height: 100%;
            max-height: 750px;
            background: #1e3f20; 
            overflow: hidden;
            box-shadow: 0 0 30px rgba(0,0,0,0.7);
        }

        .screen {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
            background: linear-gradient(135deg, #124e28 0%, #072513 100%);
            box-sizing: border-box;
            padding: 20px;
            text-align: center;
            transition: opacity 0.3s ease;
        }

        h1 {
            font-size: 32px;
            margin-bottom: 5px;
            margin-top: 0;
            text-shadow: 0 3px 6px rgba(0,0,0,0.5);
            color: #f7b500;
            letter-spacing: 1px;
        }

        p { margin: 5px 0 20px 0; color: #ddd; font-size: 15px;}

        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            width: 100%;
            max-height: 420px;
            overflow-y: auto;
            padding: 10px;
            box-sizing: border-box;
        }

        .nation-btn {
            background: rgba(255,255,255,0.08);
            border: 2px solid rgba(255,255,255,0.15);
            border-radius: 14px;
            padding: 15px 5px;
            color: white;
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 6px;
        }

        .nation-btn:active, .nation-btn.selected {
            background: #f7b500;
            color: #072513;
            border-color: #fff;
            transform: scale(0.95);
            box-shadow: 0 0 12px rgba(247, 181, 0, 0.4);
        }

        .flag-tag {
            font-size: 14px;
            background: rgba(255,255,255,0.2);
            padding: 2px 6px;
            border-radius: 4px;
            margin-bottom: 4px;
            color: #fff;
        }

        .nation-btn.selected .flag-tag {
            background: #072513;
            color: #f7b500;
        }

        button.action-btn {
            background: #f7b500;
            color: #072513;
            border: none;
            padding: 14px 45px;
            font-size: 18px;
            font-weight: bold;
            border-radius: 30px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(0,0,0,0.4);
            margin-top: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.2s;
        }

        #ingameUI {
            position: absolute;
            top: 15px; width: 100%;
            display: flex;
            justify-content: space-around;
            font-size: 15px;
            font-weight: bold;
            z-index: 5;
            text-shadow: 1px 1px 4px #000;
            pointer-events: none;
            box-sizing: border-box;
            padding: 0 10px;
        }

        #ingameUI div {
            background: rgba(0, 0, 0, 0.4);
            padding: 6px 12px;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,0.1);
        }

        #audioDebug {
            position: absolute;
            bottom: 5px;
            left: 5px;
            font-size: 10px;
            color: rgba(255,255,255,0.4);
            z-index: 100;
            pointer-events: none;
        }

        #canvasContainer {
            width: 100%;
            height: 100%;
            position: absolute;
            top: 0; left: 0;
            z-index: 1;
        }

        canvas {
            width: 100%;
            height: 100%;
            display: block;
        }

        #instructions {
            position: absolute;
            bottom: 35px;
            width: 100%;
            text-align: center;
            font-size: 14px;
            font-weight: 500;
            color: rgba(255,255,255,0.85);
            text-shadow: 1px 1px 3px #000;
            pointer-events: none;
            z-index: 5;
            animation: pulse 1.5s infinite alternate;
        }

        @keyframes pulse {
            from { opacity: 0.6; }
            to { opacity: 1; }
        }
    </style>
</head>
<body>

    <div id="gameContainer">
        
        <div id="audioDebug">Audio Status: Initializing...</div>

        <audio id="bgMusic" src="bgm.mp3" loop preload="auto"></audio>

        <div id="selectorScreen" class="screen">
            <h1>WORLD CUP 2026</h1>
            <p>Select your nation to take the pitch</p>
            <div class="grid" id="nationGrid"></div>
            <button class="action-btn" id="startBtn" disabled style="opacity: 0.4;">PLAY</button>
        </div>

        <div id="ingameUI">
            <div>TEAM: <span id="uiTeam" style="color: #f7b500;">---</span></div>
            <div>SCORE: <span id="uiScore" style="color: #4CD964;">0</span></div>
            <div>STREAK: <span id="uiStreak" style="color: #5ac8fa;">0</span></div>
        </div>
        <div id="instructions">Flick towards the corners to beat the keeper!</div>
        
        <div id="canvasContainer">
            <canvas id="gameCanvas"></canvas>
        </div>

        <div id="gameOverScreen" class="screen" style="display: none;">
            <h1 style="color: #ff3333; text-shadow: 0 0 10px rgba(255,51,51,0.3);">OUT OF THE CUP!</h1>
            <p id="finalScoreText" style="font-size: 18px;">You scored 0 penalties.</p>
            <button class="action-btn" onclick="showSelector()">TRY AGAIN</button>
        </div>

    </div>

    <script>
        const debugDiv = document.getElementById('audioDebug');

        // --- AUDIO ENGINE ---
        const SoundFX = {
            ctx: null,
            bgAudio: null,

            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
                if (!this.bgAudio) {
                    this.bgAudio = document.getElementById('bgMusic');
                    this.bgAudio.volume = 0.4; 
                    
                    this.bgAudio.addEventListener('playing', () => debugDiv.innerText = "Audio Status: Playing bgm.mp3");
                    this.bgAudio.addEventListener('error', (e) => debugDiv.innerText = "Audio Status: Error loading bgm.mp3 file!");
                }
                
                if (this.ctx && this.ctx.state === 'suspended') {
                    this.ctx.resume();
                }
            },

            startMusic() {
                this.init();
                debugDiv.innerText = "Audio Status: Attempting to play...";
                
                let playPromise = this.bgAudio.play();
                if (playPromise !== undefined) {
                    playPromise.catch(err => {
                        debugDiv.innerText = "Audio Status: Blocked by browser browser policy. Click screen!";
                    });
                }
            },

            stopMusic() {
                if (this.bgAudio) {
                    this.bgAudio.pause();
                    this.bgAudio.currentTime = 0;
                    debugDiv.innerText = "Audio Status: Stopped";
                }
            },

            playKick() {
                this.init();
                let osc = this.ctx.createOscillator();
                let gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);

                osc.type = 'sine';
                osc.frequency.setValueAtTime(140, this.ctx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(45, this.ctx.currentTime + 0.12);

                gain.gain.setValueAtTime(0.5, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.12);

                osc.start();
                osc.stop(this.ctx.currentTime + 0.12);
            },

            playSave() {
                this.init();
                let bufferSize = this.ctx.sampleRate * 0.15;
                let buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
                let data = buffer.getChannelData(0);
                for (let i = 0; i < bufferSize; i++) {
                    data[i] = Math.random() * 2 - 1;
                }

                let noise = this.ctx.createBufferSource();
                noise.buffer = buffer;

                let filter = this.ctx.createBiquadFilter();
                filter.type = 'lowpass';
                filter.frequency.setValueAtTime(350, this.ctx.currentTime);

                let gain = this.ctx.createGain();
                
                noise.connect(filter);
                filter.connect(gain);
                gain.connect(this.ctx.destination);

                gain.gain.setValueAtTime(0.6, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + 0.15);

                noise.start();
                noise.stop(this.ctx.currentTime + 0.15);
            },

            playGoal() {
                this.init();
                let now = this.ctx.currentTime;
                
                [440, 554, 659].forEach((freq, index) => {
                    let osc = this.ctx.createOscillator();
                    let gain = this.ctx.createGain();
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);

                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(freq, now);
                    osc.frequency.exponentialRampToValueAtTime(freq * 1.5, now + 0.4);

                    gain.gain.setValueAtTime(0.15, now);
                    gain.gain.exponentialRampToValueAtTime(0.001, now + 0.5);

                    osc.start(now);
                    osc.stop(now + 0.5);
                });
            },

            playGameOver() {
                this.init();
                let osc = this.ctx.createOscillator();
                let gain = this.ctx.createGain();
                osc.connect(gain);
                gain.connect(this.ctx.destination);

                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(180, this.ctx.currentTime);
                osc.frequency.linearRampToValueAtTime(70, this.ctx.currentTime + 0.6);

                let filter = this.ctx.createBiquadFilter();
                filter.type = 'lowpass';
                filter.frequency.setValueAtTime(300, this.ctx.currentTime);
                
                osc.disconnect(gain);
                osc.connect(filter);
                filter.connect(gain);

                gain.gain.setValueAtTime(0.3, this.ctx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + 0.6);

                osc.start();
                osc.stop(this.ctx.currentTime + 0.6);
            }
        };

        // --- GAME SYSTEM CODE ---
        const nations = [
            { name: 'Argentina', tag: 'ARG', color: '#74ACDF' },
            { name: 'Brazil', tag: 'BRA', color: '#009c3b' },
            { name: 'England', tag: 'ENG', color: '#ce1124' },
            { name: 'France', tag: 'FRA', color: '#002395' },
            { name: 'Germany', tag: 'GER', color: '#111111' },
            { name: 'Spain', tag: 'ESP', color: '#c60b1e' },
            { name: 'USA', tag: 'USA', color: '#0a3161' },
            { name: 'Mexico', tag: 'MEX', color: '#006847' },
            { name: 'Portugal', tag: 'POR', color: '#ff0000' }
        ];

        let selectedNation = null;
        let score = 0;
        let streak = 0;

        const grid = document.getElementById('nationGrid');
        const startBtn = document.getElementById('startBtn');

        nations.forEach(nation => {
            const btn = document.createElement('div');
            btn.className = 'nation-btn';
            btn.innerHTML = `<span class="flag-tag">${nation.tag}</span><span>${nation.name}</span>`;
            btn.addEventListener('click', () => {
                // WAKES AND STARTS MUSIC ON USER ACTION GESTURE
                SoundFX.startMusic();
                
                document.querySelectorAll('.nation-btn').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                selectedNation = nation;
                startBtn.disabled = false;
                startBtn.style.opacity = "1";
            });
            grid.appendChild(btn);
        });

        startBtn.addEventListener('click', startGame);

        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');

        function resizeCanvas() {
            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = canvas.parentElement.clientHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        let ball, keeper, goal, gameState;
        
        function initEntities() {
            goal = {
                x: canvas.width * 0.15,
                y: 140,
                w: canvas.width * 0.7,
                h: 130
            };

            ball = {
                startX: canvas.width / 2,
                startY: canvas.height - 120,
                x: canvas.width / 2,
                y: canvas.height - 120,
                targetX: 0,
                targetY: 0,
                radius: 22,       
                startRadius: 22,
                targetRadius: 8,  
                progress: 0,      
                speed: 0.038,
                bounceVx: 0,
                bounceVy: 0
            };

            // LOGARITHMIC CURVE SCALING
            let gradualScalingFactor = Math.log1p(streak) * 0.35; 
            let baseKeeperSpeed = 2.2 + gradualScalingFactor;

            keeper = {
                x: canvas.width / 2,
                y: 195,
                w: 54, 
                h: 70,
                dir: Math.random() < 0.5 ? 1 : -1,
                speed: Math.min(baseKeeperSpeed, 5.0), 
                state: 'idling', 
                targetX: canvas.width / 2
            };

            gameState = 'aiming';
        }

        let touchStart = { x: 0, y: 0 };
        let touchTime = 0;
        
        function handleStart(x, y) {
            if (gameState !== 'aiming') return;
            touchStart.x = x;
            touchStart.y = y;
            touchTime = Date.now();
        }

        function handleEnd(x, y) {
            if (gameState !== 'aiming') return;
            
            let diffX = x - touchStart.x;
            let diffY = y - touchStart.y;
            let duration = Date.now() - touchTime;

            if (diffY < -30 && duration < 400) { 
                SoundFX.playKick();

                ball.targetX = ball.startX + (diffX * 1.3);
                ball.targetY = ball.startY + (diffY * 1.1);
                
                ball.targetY = Math.max(goal.y + 10, Math.min(goal.y + goal.h - 10, ball.targetY));
                ball.targetX = Math.max(goal.x - 30, Math.min(goal.x + goal.w + 30, ball.targetX));

                ball.progress = 0;
                gameState = 'shooting';
                keeper.state = 'diving';
                
                let errorMargin = (Math.random() * 80 - 40); 
                keeper.targetX = Math.max(goal.x + 10, Math.min(goal.x + goal.w - 10, ball.targetX + errorMargin));
            }
        }

        canvas.addEventListener('touchstart', (e) => handleStart(e.touches[0].clientX, e.touches[0].clientY));
        canvas.addEventListener('touchend', (e) => handleEnd(e.changedTouches[0].clientX, e.changedTouches[0].clientY));
        
        canvas.addEventListener('mousedown', (e) => handleStart(e.clientX, e.clientY));
        canvas.addEventListener('mouseup', (e) => handleEnd(e.clientX, e.clientY));

        function update() {
            if (gameState === 'aiming') {
                keeper.x += keeper.speed * keeper.dir;
                if (keeper.x - keeper.w/2 < goal.x || keeper.x + keeper.w/2 > goal.x + goal.w) {
                    keeper.dir *= -1;
                    keeper.x = keeper.x - keeper.w/2 < goal.x ? goal.x + keeper.w/2 : goal.x + goal.w - keeper.w/2;
                }
            }

            if (gameState === 'shooting') {
                ball.progress += ball.speed;
                if (ball.progress > 1) ball.progress = 1;

                ball.x = ball.startX + (ball.targetX - ball.startX) * ball.progress;
                ball.y = ball.startY + (ball.targetY - ball.startY) * ball.progress;
                ball.radius = ball.startRadius + (ball.targetRadius - ball.startRadius) * ball.progress;

                if (keeper.state === 'diving') {
                    keeper.x += (keeper.targetX - keeper.x) * 0.03; 
                }

                if (ball.progress >= 1) {
                    let hitKeeperWidth = keeper.w / 2 + 5; 
                    if (ball.x >= keeper.x - hitKeeperWidth && ball.x <= keeper.x + hitKeeperWidth) {
                        SoundFX.playSave();
                        gameState = 'rebounding';
                        let hitOffset = (ball.x - keeper.x) / hitKeeperWidth; 
                        ball.bounceVx = hitOffset * 4;   
                        ball.bounceVy = 5.5;             
                        return;
                    }

                    if (ball.x >= goal.x && ball.x <= goal.x + goal.w && ball.y >= goal.y && ball.y <= goal.y + goal.h) {
                        processResult(true); 
                    } else {
                        processResult(false); 
                    }
                    return;
                }
            }

            if (gameState === 'rebounding') {
                ball.x += ball.bounceVx;
                ball.y += ball.bounceVy;
                
                if (ball.radius < ball.startRadius * 0.8) {
                    ball.radius += 0.4;
                }

                ball.bounceVx *= 0.98;
                ball.bounceVy *= 0.95;

                if (ball.bounceVy < 0.8) {
                    processResult(false);
                }
            }
        }

        function draw() {
            // 1. THE PITCH PERSPECTIVE
            let pitchGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
            pitchGrad.addColorStop(0, '#0a230c'); 
            pitchGrad.addColorStop(0.3, '#113b15');
            pitchGrad.addColorStop(1, '#1e5e25');   
            ctx.fillStyle = pitchGrad;
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Striped Grass Pattern
            ctx.fillStyle = 'rgba(255, 255, 255, 0.03)';
            for (let i = 0; i < 6; i++) {
                if (i % 2 === 0) {
                    ctx.beginPath();
                    let topY = goal.y + goal.h + (i * 40);
                    let botY = goal.y + goal.h + ((i + 1) * 70);
                    ctx.moveTo(0, topY);
                    ctx.lineTo(canvas.width, topY);
                    ctx.lineTo(canvas.width, botY);
                    ctx.lineTo(0, botY);
                    ctx.fill();
                }
            }

            // 2. STADIUM WHITE LINES
            ctx.strokeStyle = 'rgba(255,255,255,0.4)';
            ctx.lineWidth = 3;
            
            ctx.beginPath();
            ctx.moveTo(goal.x - 40, goal.y + goal.h);
            ctx.lineTo(0, canvas.height - 50);
            ctx.moveTo(goal.x + goal.w + 40, goal.y + goal.h);
            ctx.lineTo(canvas.width, canvas.height - 50);
            ctx.moveTo(0, canvas.height - 50);
            ctx.lineTo(canvas.width, canvas.height - 50);
            ctx.stroke();
            
            ctx.fillStyle = 'rgba(255,255,255,0.8)';
            ctx.beginPath();
            ctx.arc(canvas.width/2, canvas.height - 120, 6, 0, Math.PI * 2);
            ctx.fill();

            // 3. THE GOAL NET DEPTH
            let netShadow = ctx.createLinearGradient(0, goal.y, 0, goal.y + goal.h);
            netShadow.addColorStop(0, 'rgba(0,0,0,0.6)');
            netShadow.addColorStop(1, 'rgba(0,0,0,0.1)');
            ctx.fillStyle = netShadow;
            ctx.fillRect(goal.x, goal.y, goal.w, goal.h);

            // Net Grid Lines
            ctx.strokeStyle = 'rgba(255,255,255,0.15)';
            ctx.lineWidth = 1;
            let meshSize = 10;
            for (let x = goal.x; x <= goal.x + goal.w; x += meshSize) {
                ctx.beginPath(); ctx.moveTo(x, goal.y); ctx.lineTo(x, goal.y + goal.h); ctx.stroke();
            }
            for (let y = goal.y; y <= goal.y + goal.h; y += meshSize) {
                ctx.beginPath(); ctx.moveTo(goal.x, y); ctx.lineTo(goal.x + goal.w, y); ctx.stroke();
            }

            // Goalposts Frames
            ctx.strokeStyle = '#ffffff';
            ctx.lineWidth = 8;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.shadowBlur = 10;
            ctx.shadowColor = 'rgba(255,255,255,0.3)';
            ctx.beginPath();
            ctx.moveTo(goal.x, goal.y + goal.h);
            ctx.lineTo(goal.x, goal.y); 
            ctx.lineTo(goal.x + goal.w, goal.y); 
            ctx.lineTo(goal.x + goal.w, goal.y + goal.h); 
            ctx.stroke();
            ctx.shadowBlur = 0; 

            // 4. BALL DROP SHADOW
            ctx.fillStyle = 'rgba(0,0,0,0.35)';
            ctx.beginPath();
            let shadowY;
            let shadowScale;
            if (gameState === 'rebounding') {
                shadowY = ball.y + 25; 
                shadowScale = Math.max(0.3, (1 - (ball.bounceVy / 10)));
            } else {
                shadowY = ball.startY + ((goal.y + goal.h + 10) - ball.startY) * ball.progress;
                shadowScale = 1 - (ball.progress * 0.4);
            }
            ctx.ellipse(ball.x, shadowY, ball.radius * 1.1 * shadowScale, ball.radius * 0.4 * shadowScale, 0, 0, Math.PI * 2);
            ctx.fill();

            // 5. GOALKEEPER OVERHAUL
            let gkColor = selectedNation ? selectedNation.color : '#ff5722';
            ctx.save();
            ctx.translate(keeper.x, keeper.y);

            ctx.fillStyle = 'rgba(0,0,0,0.3)';
            ctx.beginPath();
            ctx.ellipse(0, 52, keeper.w * 0.6, 10, 0, 0, Math.PI * 2);
            ctx.fill();

            // Boots & Socks
            ctx.fillStyle = '#222'; 
            ctx.fillRect(-18, 44, 10, 8);
            ctx.fillRect(8, 44, 10, 8);
            ctx.fillStyle = '#fff'; 
            ctx.fillRect(-16, 32, 7, 12);
            ctx.fillRect(9, 32, 7, 12);

            // Kit Shorts & Torso
            ctx.fillStyle = '#111111'; 
            ctx.fillRect(-18, 20, 36, 14);
            ctx.fillStyle = gkColor;
            ctx.fillRect(-20, -15, 40, 35);

            // Dynamic Diving Arms
            ctx.fillStyle = gkColor;
            ctx.strokeStyle = '#fff';
            ctx.lineWidth = 2;
            if (gameState === 'shooting' || keeper.state === 'diving') {
                ctx.fillRect(-32, -10, 12, 10); 
                ctx.fillRect(20, -10, 12, 10);  
            } else {
                ctx.fillRect(-28, -5, 9, 22);
                ctx.fillRect(19, -5, 9, 22);
            }

            // Head and Face Elements
            ctx.fillStyle = '#ffdbac';
            ctx.beginPath();
            ctx.arc(0, -26, 11, 0, Math.PI * 2);
            ctx.fill();
            ctx.fillStyle = '#333';
            ctx.fillRect(-8, -37, 16, 5);

            ctx.restore();

            // 6. SOCCER BALL WITH PANEL SPIN ENGINE
            ctx.save();
            ctx.translate(ball.x, ball.y);
            let spinAngle = (ball.progress * 4.5); 
            ctx.rotate(spinAngle);

            ctx.fillStyle = '#ffffff';
            ctx.strokeStyle = '#1a1a1a';
            ctx.lineWidth = Math.max(1.5, ball.radius * 0.08);
            ctx.beginPath();
            ctx.arc(0, 0, Math.max(ball.radius, 3), 0, Math.PI * 2);
            ctx.fill();
            ctx.stroke();
            
            ctx.fillStyle = '#1a1a1a';
            let r = ball.radius;
            if (r > 4) {
                ctx.beginPath();
                ctx.arc(0, 0, r * 0.32, 0, Math.PI * 2); 
                ctx.fill();

                ctx.strokeStyle = 'rgba(0,0,0,0.4)';
                ctx.lineWidth = Math.max(1, r * 0.05);
                for (let a = 0; a < Math.PI * 2; a += (Math.PI * 2 / 5)) {
                    ctx.beginPath();
                    ctx.moveTo(Math.cos(a) * (r * 0.32), Math.sin(a) * (r * 0.32));
                    ctx.lineTo(Math.cos(a) * r, Math.sin(a) * r);
                    ctx.stroke();
                }
            }
            ctx.restore();

            // 7. RESULT INTERACTIVE TEXT
            if (gameState === 'result') {
                ctx.fillStyle = feedbackColor;
                ctx.font = 'bold 44px sans-serif';
                ctx.textAlign = 'center';
                ctx.shadowBlur = 12;
                ctx.shadowColor = 'rgba(0,0,0,0.8)';
                ctx.fillText(feedbackText, canvas.width / 2, canvas.height * 0.52);
                ctx.shadowBlur = 0;
            }
        }

        let feedbackText = "";
        let feedbackColor = "#fff";

        function processResult(isGoal) {
            gameState = 'result';
            if (isGoal) {
                SoundFX.playGoal();
                
                score++;
                streak++;
                feedbackText = "GOAL!";
                feedbackColor = "#4CD964";
                
                document.getElementById('uiScore').innerText = score;
                document.getElementById('uiStreak').innerText = streak;
                
                setTimeout(() => {
                    initEntities();
                }, 1400);
            } else {
                SoundFX.stopMusic();     
                SoundFX.playGameOver();  
                
                feedbackText = "SAVED!";
                feedbackColor = "#FF3B30";
                setTimeout(endGame, 1400);
            }
        }

        function gameLoop() {
            update();
            draw();
            if (gameState !== 'over') {
                requestAnimationFrame(gameLoop);
            }
        }

        function startGame() {
            SoundFX.startMusic();

            document.getElementById('selectorScreen').style.display = 'none';
            document.getElementById('uiTeam').innerText = selectedNation.tag + " " + selectedNation.name;
            
            score = 0;
            streak = 0;
            document.getElementById('uiScore').innerText = score;
            document.getElementById('uiStreak').innerText = streak;
            
            initEntities();
            gameLoop();
        }

        function endGame() {
            gameState = 'over';
            document.getElementById('finalScoreText').innerText = `You scored ${score} goals for ${selectedNation.name}!`;
            document.getElementById('gameOverScreen').style.display = 'flex';
        }

        function showSelector() {
            document.getElementById('gameOverScreen').style.display = 'none';
            document.getElementById('selectorScreen').style.display = 'flex';
        }

        resizeCanvas();
    </script>
</body>
</html>
